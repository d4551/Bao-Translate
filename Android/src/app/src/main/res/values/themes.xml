<resources>
  <style name="Theme.Gallery" parent="android:Theme.Material.Light.NoActionBar">
      <!-- Match the app surface so the pre-Compose launch frame doesn't flash white -->
      <item name="android:windowBackground">@color/launch_window_background</item>
  </style>
  <style name="Theme.Gallery.SplashScreen" parent="Theme.SplashScreen">
      <!-- Surface (surfaceLight) so the splash matches the post-splash window with no color seam -->
      <item name="windowSplashScreenBackground">#FFFFFFFF</item>
      <!-- Icon carries the brand: character on a baked blue disc (legible on any surface) -->
      <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_splash</item>
      <item name="postSplashScreenTheme">@style/Theme.Gallery</item>
  </style>
</resources>
